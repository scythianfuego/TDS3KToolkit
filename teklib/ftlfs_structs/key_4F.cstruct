// VHTTP connect/report URLs plus Ethernet HTTP port, key 0x4F.
// ETHERnet:HTTPPORT is special-cased as network parameter index 0x0B and
// saved here rather than in the key 0x43 eleven-entry table.

typedef struct
{
    char connectUrl0[0xC9];
    char connectUrl1[0xC9];
    char connectUrl2[0xC9];
    char ethernetHttpPort[0x0F]; // ETHERnet:HTTPPORT, default "80".
} file;
