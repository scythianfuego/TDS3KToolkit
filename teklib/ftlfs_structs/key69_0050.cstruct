// Mask-test global state, older 80-byte record.
//
// This version omits the two final words present in current 88-byte records.

typedef struct
{
    double maskpreAmplitude;
    double maskpreVScale;
    double maskpreVOffset;
    double maskpreVPos;
    double maskpreHScale;
    double maskpreHTrigPos;
    double maskpreWidth;
    double maskpreTrigToSamp;
    uint32 maskprePreSampBits;
    uint32 maskprePatternBits;
    uint32 maskpreRecordLength;
    uint32 maskpreSerialTrig;
} file;
