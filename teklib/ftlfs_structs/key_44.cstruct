// Ethernet network-printer / VHTTP file-entry table, key 0x44.
// Each 0xC3-byte entry is three 0x41-byte string fields.
// Manual ETHERnet:NETPRInter:ADD/DELEte/REName/SELect:ALLInfo uses this
// exact triple order: printer name; printer server name; print server IP address.

typedef struct
{
    char printerName[0x41];
    char printServerName[0x41];
    char printServerIpAddress[0x41];
} network_printer_entry;

typedef struct
{
    network_printer_entry entry[21];
} file;
